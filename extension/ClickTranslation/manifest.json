{
    "manifest_version": 3,
    "name": "번역!",
    "version": "1.0",
    "description": "Translation !",
    "permissions": [
        "tabs",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "http://localhost:5000/*",
        "http://127.0.0.1:5000/*"
    ],
    "action": {
        "default_icon": "translation.png",
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}